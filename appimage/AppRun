#!/bin/sh
# AppRun - Entry point for AppImage

HERE="$(dirname "$(readlink -f "${0}")")"

# Set up environment
export PYTHONPATH="${HERE}/usr/lib/python3/site-packages:${PYTHONPATH}"
export PATH="${HERE}/usr/bin:${PATH}"
export LD_LIBRARY_PATH="${HERE}/usr/lib:${HERE}/usr/lib/x86_64-linux-gnu:${LD_LIBRARY_PATH}"

# Qt plugin path - find plugins directory
QT_PLUGINS="${HERE}/usr/lib/python3/site-packages/PyQt6/Qt6/plugins"
if [ ! -d "${QT_PLUGINS}" ]; then
    QT_PLUGINS="${HERE}/usr/lib/qt6/plugins"
fi
export QT_PLUGIN_PATH="${QT_PLUGINS}:${QT_PLUGIN_PATH}"

QML_PATH="${HERE}/usr/lib/python3/site-packages/PyQt6/Qt6/qml"
if [ ! -d "${QML_PATH}" ]; then
    QML_PATH="${HERE}/usr/lib/qt6/qml"
fi
export QML2_IMPORT_PATH="${QML_PATH}:${QML2_IMPORT_PATH}"

# Font config
export FONTCONFIG_FILE="${HERE}/usr/etc/fonts/fonts.conf"
export FONTCONFIG_PATH="${HERE}/usr/etc/fonts"

# XDG paths
export XDG_DATA_DIRS="${HERE}/usr/share:${XDG_DATA_DIRS}"
export XDG_CONFIG_DIRS="${HERE}/usr/etc/xdg:${XDG_CONFIG_DIRS}"

# Create config directory if needed
mkdir -p "${HOME}/.config/workout-tracker"

# Run the application
cd "${HERE}"
exec python3 -m workout_tracker.main "$@"